<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="202603020001" author="system">
        <addColumn tableName="jhi_user">
            <column name="department_id" type="bigint">
                <constraints nullable="true" foreignKeyName="fk_user_department" references="department(id)"/>
            </column>
        </addColumn>

        <!-- Ensure fallback department exists for legacy users -->
        <sql>
            INSERT INTO department (id, code, name, description)
            SELECT 1, 'DEFAULT', 'Default Department', 'Auto-created by Liquibase migration'
            WHERE NOT EXISTS (SELECT 1 FROM department WHERE id = 1);
        </sql>

        <!-- Set default department_id = 1 for existing users -->
        <update tableName="jhi_user">
            <column name="department_id" valueNumeric="1"/>
            <where>department_id IS NULL</where>
        </update>
    </changeSet>
</databaseChangeLog>
