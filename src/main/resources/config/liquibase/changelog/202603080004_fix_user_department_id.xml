<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Fix: Add department_id to jhi_user if missing (e.g. DB created before migration or migration failed) -->
    <changeSet id="202603080004-fix-user-department" author="system">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="jhi_user" columnName="department_id"/>
            </not>
        </preConditions>
        <addColumn tableName="jhi_user">
            <column name="department_id" type="bigint">
                <constraints nullable="true" foreignKeyName="fk_user_department" references="department(id)"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>
