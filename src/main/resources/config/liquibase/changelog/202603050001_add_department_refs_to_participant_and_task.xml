<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="202603050001-1" author="system">
        <addColumn tableName="meeting_task">
            <column name="department_id" type="bigint" />
        </addColumn>

        <addColumn tableName="meeting_participant">
            <column name="department_id" type="bigint" />
        </addColumn>

        <dropNotNullConstraint tableName="meeting_participant" columnName="user_id" columnDataType="bigint"/>

        <addForeignKeyConstraint
            baseTableName="meeting_task"
            baseColumnNames="department_id"
            referencedTableName="department"
            referencedColumnNames="id"
            constraintName="fk_meeting_task__department_id"/>

        <addForeignKeyConstraint
            baseTableName="meeting_participant"
            baseColumnNames="department_id"
            referencedTableName="department"
            referencedColumnNames="id"
            constraintName="fk_meeting_participant__department_id"/>
    </changeSet>
</databaseChangeLog>
